# ─── EDU-TECH Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# JWT signing key – use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=replace-with-strong-password

# Gmail app-password used to send OTP emails
SENDER_EMAIL=collegedaymail1@gmail.com
SENDER_PASSWORD=replace-with-gmail-app-password

# Comma-separated list of allowed CORS origins
# For local dev: http://localhost:3000
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" only during local development
FLASK_DEBUG=false
